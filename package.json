{
  "name": "loony-fetch",
  "version": "1.0.0",
  "description": "Lightweight, secure Promise-based HTTP client for Node.js and the browser. Supports interceptors, redirect following, AbortController, and hardened against prototype pollution, header injection, and XSRF token leakage.",
  "private": false,
  "type": "module",
  "main": "./lib/index.cjs",
  "module": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js",
      "require": "./lib/index.cjs"
    }
  },
  "files": [
    "lib",
    "docs",
    "README.md"
  ],
  "keywords": [
    "http",
    "https",
    "fetch",
    "request",
    "client",
    "ajax",
    "xhr",
    "node",
    "browser",
    "promise",
    "interceptors",
    "secure"
  ],
  "scripts": {
    "clean": "rm -rf lib dist",
    "build": "npm run clean && tsup ./src/* --format cjs,esm --dts --out-dir lib",
    "prepublishOnly": "npm run build"
  },
  "author": "Sankar Boro",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/sankar-boro/loony-fetch.git"
  },
  "homepage": "https://github.com/sankar-boro/loony-fetch#readme",
  "bugs": {
    "url": "https://github.com/sankar-boro/loony-fetch/issues"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18"
  }
}
